{
  // Format files on save. Shell files go through shfmt (via the shell-format
  // extension) and every file's whitespace/encoding is normalized by the
  // EditorConfig extension — both driven by this repo's .editorconfig, so saving
  // in the editor matches `just fmt` and the CI format-check exactly. No Node
  // toolchain (Prettier/ESLint) is used — see ADR 0002 (native toolchain).
  "editor.formatOnSave": true,
  // Shell: format with shfmt. The extension invokes shfmt with no printer flags,
  // so shfmt reads .editorconfig (2-space indent, indented case bodies, ...).
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  // Let shfmt read .editorconfig instead of the extension's own flag settings, so
  // editor formatting matches `just fmt` and CI exactly.
  "shellformat.useEditorConfig": true,
  // shell-format does not bundle shfmt — it must find one on PATH or via this path.
  // Cursor launched from the macOS GUI does not inherit your shell PATH, so we pin the
  // Homebrew shfmt (the same binary `just fmt` uses). This is the Apple-Silicon path;
  // on Intel macOS (/usr/local/bin) or Linux (/usr/bin) override it in your own user
  // settings.
  "shellformat.path": "/opt/homebrew/bin/shfmt",
  // `justfile` has its own syntax — it is neither shell nor Markdown. Editors can
  // misdetect it (e.g. as Markdown) and a format-on-save formatter then mangles it
  // (inserting blank lines, escaping `*`). Pin it to the Makefile grammar (close
  // enough for highlighting) and turn formatting off so nothing rewrites it.
  "files.associations": {
    "justfile": "makefile",
    "*.just": "makefile"
  },
  "[makefile]": {
    "editor.formatOnSave": false
  }
}
