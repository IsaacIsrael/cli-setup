# Cursor — rule symlinks (recreated by /setup) and ephemeral scratch space
.cursor/rules/
.scratch/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Editor / IDE
*.swp
*.swo
*~

# Local environment
.env
.env.local

# ShellSpec test output
coverage/
.shellspec-local

# mdBook build output
docs/book/
book/

# Tag-sourced releases (ADR 0010): the version lives in the git tag and the
# changelog in the GitHub Releases — never commit these. Guard against accidents.
# `just build` materializes src/VERSION + src/CHANGELOG.md at build time.
/VERSION
/src/VERSION
/CHANGELOG.md
/src/CHANGELOG.md
/CHANGELOG

# Release asset build output (`just build`) — the asset ships via the GitHub
# Release, never the repo.
/dist/
