#!/usr/bin/env bash
# cli-setup entrypoint — the command dispatcher (built incrementally in #8).
set -euo pipefail

PROG=cli-setup

# Resolve the install root (the parent of this script's bin/ directory),
# following symlinks so paths hold whether the entrypoint runs in place
# (src/bin/cli-setup) or via the symlink install.sh puts on PATH
# (~/.cli-setup/bin/cli-setup). macOS lacks `readlink -f`, so walk the links.
resolve_root() {
  source=${BASH_SOURCE[0]}
  while [ -h "$source" ]; do
    dir=$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)
    source=$(readlink "$source")
    case $source in
      /*) ;;
      *) source=$dir/$source ;;
    esac
  done
  dir=$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)
  dirname "$dir"
}

print_version() {
  # install.sh materializes <root>/VERSION from the released tag (ADR 0010).
  line=""
  IFS= read -r line <"$(resolve_root)/VERSION" || true
  printf '%s\n' "$line"
}

print_help() {
  cat <<EOF
$PROG — guided macOS dev environment setup.

Usage:
  $PROG [command] [options]

Commands (planned):
  doctor <profile>    Diagnose what's missing for a profile (read-only).
  setup <profile>     Install and adjust the missing tools for a profile.
  update <profile>    Reconcile installed tools to the team config.
  config <action>     Manage the team config.

Options:
      --version       Print the installed version and exit.
  -h, --help          Print this help and exit.
  -v, --verbose       Show detailed output.

Run with no arguments to print this help.
EOF
}

case "${1:-}" in
  "")
    print_help
    exit 0
    ;;
  --version)
    print_version
    exit 0
    ;;
  -h | --help)
    print_help
    exit 0
    ;;
esac
