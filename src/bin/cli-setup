#!/usr/bin/env bash
# cli-setup entrypoint — the command dispatcher (built incrementally in #8).
set -euo pipefail

PROG=cli-setup

# Locate boot/ from the entrypoint path ($0, symlink-safe) before bootstrap loads.
_cli_setup_source=$0
while [ -h "$_cli_setup_source" ]; do
  _dir=$(cd -P "$(dirname "$_cli_setup_source")" >/dev/null 2>&1 && pwd)
  _cli_setup_source=$(readlink "$_cli_setup_source")
  case $_cli_setup_source in
    /*) ;;
    *) _cli_setup_source=$_dir/$_cli_setup_source ;;
  esac
done
_bin_dir=$(cd -P "$(dirname "$_cli_setup_source")" >/dev/null 2>&1 && pwd)
_root=$(dirname "$_bin_dir")
# shellcheck source=../boot/bootstrap.sh
source "$_root/boot/bootstrap.sh"
source_lib lib/version
source_lib lib/help

fail() {
  printf '%s: %s\n' "$PROG" "$1" >&2
  printf "Run '%s --help' for usage.\n" "$PROG" >&2
  exit 2
}

case "${1:-}" in
  "")
    print_help "$PROG"
    exit 0
    ;;
  --version)
    installed_version
    exit 0
    ;;
  -h | --help)
    print_help "$PROG"
    exit 0
    ;;
  -v | --verbose)
    # Accepted as an advertised global flag; the command slices wire it into
    # output verbosity. With no command to run, fall back to the help.
    print_help "$PROG"
    exit 0
    ;;
  doctor | setup | update | config)
    fail "command '$1' is planned but not implemented yet"
    ;;
  -*)
    fail "unknown option '$1'"
    ;;
  *)
    fail "unknown command '$1'"
    ;;
esac
